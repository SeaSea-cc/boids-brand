# OS / editor
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
*.iml

# Logs
*.log

# Local agent caches (Qoder / Claude / Cursor / Windsurf / Trae)
.qoder/
.claude/cache/
.cursor/cache/
.codex-tools/
.windsurf/
.trae/
.npm-cache/

# Local scratch
/_local/
/_scratch/
scripts/.cache/

# Node (if any tooling is added later)
node_modules/
.pnpm-store/

# Image hygiene — only PNG exemplars under references/exemplars/ are allowed in this repo.
# Per-deck / per-campaign output belongs in <workspace>/brand-outputs/, not here.
*.jpg
*.jpeg
*.webp
*.avif
*.gif
*.tiff
*.bmp
*.heic
*.heif
*.psd
*.ai
*.sketch
*.fig
*.pdf

# Anywhere else than references/exemplars/, PNGs are also blocked.
# (PNGs explicitly allowed under references/exemplars/ — see references/exemplars/README.md.)
/*.png
/**/*.png
!references/exemplars/**/*.png
